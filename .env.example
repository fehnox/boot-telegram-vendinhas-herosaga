# Copie este arquivo para `.env` e preencha os valores abaixo.

# Obrigatórios para alertas no Telegram e para o GitHub Actions
TOKEN=your_bot_token_here
CHAT_ID=your_chat_id_here
# Alternativas compatíveis
BOT_TOKEN=
TELEGRAM_CHAT_ID=
CHAT_IDS=

# Opcional
SHOP_URL=https://herosaga.com.br/?module=vending&action=viewshop&id=30313
DISCORD_WEBHOOK=
TELEGRAM_MESSAGE=
DISCORD_MESSAGE=

# Ajustes do worker
NOTIFY_COOLDOWN=30
REQUEST_TIMEOUT=20
## O teste de conectividade é feito manualmente pelo botão do app desktop.

# UI local para cadastrar lojinhas
UI_HOST=127.0.0.1
UI_PORT=8787

# Sync da UI para VPS (git pull remoto)
VPS_SSH_TARGET=
VPS_SSH_KEY_PATH=
VPS_PROJECT_DIR=/home/ubuntu/boot-telegram-vendinhas-herosaga
