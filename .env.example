# Copie este arquivo para `.env` e preencha os valores abaixo.

# Obrigatórios para alertas no Telegram
BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Opcional
SHOP_URL=https://herosaga.com.br/?module=vending&action=viewshop&id=30313
DISCORD_WEBHOOK=

# Ajustes do worker
CHECK_INTERVAL=60
NOTIFY_COOLDOWN=300
REQUEST_TIMEOUT=20
ERROR_RETRY_DELAY=60
